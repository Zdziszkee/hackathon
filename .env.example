"""Environment variables for EWS Phase 1 ingestion layer.

Copy to `.env` and fill in values. All keys are FREE (per spec — no paid APIs).

uv does not read `.env` automatically. Load it explicitly, either per-command:
    uv run --env-file .env python -m ews_ingest validate
or once per shell session:
    export UV_ENV_FILE=.env

Sources marked ``env_required`` in ``sources.yaml`` will skip when their var is unset.

SEC_USER_AGENT is REQUIRED (free, no key): a descriptive contact per sec.gov policy.
"""

# --- Required (no API key, but descriptive header mandated by sec.gov) ---
SEC_USER_AGENT="Your Name your.email@example.com"

# --- Free API keys (register at each provider; leave empty to skip that source) ---
FRED_API_KEY=""
EIA_API_KEY=""
BLS_API_KEY=""
BEA_API_KEY=""
CENSUS_API_KEY=""
USDA_API_KEY=""
FINRA_API_KEY=""
ALPHAVANTAGE_API_KEY=""
TWELVEDATA_API_KEY=""
CSL_API_KEY=""
OPENSANCTIONS_API_KEY=""
OPENCORPORATES_API_TOKEN=""

# --- UN Comtrade modern API (optional; legacy API works without a key) ---
UN_COMTRADE_API_KEY=""



# --- Stocktwits API (free key, rate-limited) ---
STOCKTWITS_ACCESS_TOKEN=""

# --- Google Trends official API (alpha/waitlist); unofficial fallback used otherwise ---
GOOGLE_TRENDS_API_KEY=""

# --- Landing zone location (default: ./data/landing) ---
EWS_LANDING_DIR="./data/landing"

# --- Integration tests gate (set to 1 to run live-network tests) ---
# EWS_RUN_INTEGRATION=1
